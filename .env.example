# ── IncidentMind env template (copy to .env / .env.local, fill in, never commit secrets)

# ── Backend (FastAPI) ──────────────────────────────────────────────
# Toggle adapters: keep mocks=true until the real services are wired (hour 0–4).
USE_MOCK_AGENT=true
USE_MOCK_HINDSIGHT=true

# OpenAI (baseline control + reflect reasoning)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_FALLBACK_MODEL=gpt-4o-mini

# Hindsight (memory source of truth) — Cloud promo MEMHACK6 or Docker self-host
HINDSIGHT_API_KEY=
HINDSIGHT_BANK_ID=
HINDSIGHT_BASE_URL=

# OpenClaw (hosted diagnosis agent + Hindsight plugin)
OPENCLAW_BASE_URL=
OPENCLAW_AGENT_ID=
OPENCLAW_API_KEY=

# CORS — comma-separated frontend origins
CORS_ORIGINS=http://localhost:3000

# Business counter
COST_PER_MINUTE=500

# ── Frontend (Next.js) ─────────────────────────────────────────────
NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXT_PUBLIC_COST_PER_MINUTE=500

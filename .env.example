# ── IncidentMind env template (copy to .env, fill in, never commit secrets)

# ── Adapter toggles ────────────────────────────────────────────────
# Keep mocks=true to run with ZERO credentials. Flip to false per service as you
# wire real keys. Selectors fall back to the mock automatically if a real service
# is misconfigured or down (demo-safe, BUILD_PLAN §11).
USE_MOCK_AGENT=true          # false -> OpenClawAgent (needs OpenClaw CLI + OPENCLAW_AGENT_ID)
USE_MOCK_HINDSIGHT=true      # false -> RealHindsightClient (needs HINDSIGHT_* below)

# Pin "today" so recency/freshness are stable on stage (matches the seed corpus).
DEMO_TODAY=2026-06-07

# ── OpenAI (baseline control + the reasoning model OpenClaw uses) ───
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o
OPENAI_FALLBACK_MODEL=gpt-4o-mini

# ── Hindsight Cloud (memory source of truth · promo MEMHACK6 → $50) ─
HINDSIGHT_BASE_URL=https://api.hindsight.vectorize.io
HINDSIGHT_API_KEY=
HINDSIGHT_BANK_ID=incidentmind
HINDSIGHT_TIMEOUT=30

# ── OpenClaw (hosted diagnosis agent + Hindsight plugin) ───────────
OPENCLAW_BIN=openclaw         # path to the openclaw CLI if not on PATH
OPENCLAW_AGENT_ID=sre         # the configured SRE agent id
OPENCLAW_TIMEOUT=60

# ── App ────────────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000
COST_PER_MINUTE=500

# ── Frontend (Next.js) ─────────────────────────────────────────────
NEXT_PUBLIC_API_BASE=http://localhost:8000
NEXT_PUBLIC_COST_PER_MINUTE=500
